# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

ENV['RCT_USE_PREBUILT_RNCORE'] = '0'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ReactNativePharmaScanner' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/../.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix Clang module definition mismatch for NetworkIOAgent::streams_.
    # NetworkIOAgent.h uses an anonymous namespace for StreamsMap, which
    # produces different types when compiled in different Clang module
    # contexts (React_RCTAppDelegate vs jsinspector_modern). Replacing the
    # anonymous namespace with a named one resolves the type identity conflict.
    rn_path = config[:reactNativePath]
    network_io_h = File.join(rn_path, 'ReactCommon/jsinspector-modern/NetworkIOAgent.h')
    network_io_cpp = File.join(rn_path, 'ReactCommon/jsinspector-modern/NetworkIOAgent.cpp')

    # Patch .h: rename anonymous namespace to networkioagent_detail
    if File.exist?(network_io_h)
      content = File.read(network_io_h)
      if content.include?('namespace {')
        patched = content
          .sub("namespace {\nclass Stream;", "namespace networkioagent_detail {\nclass Stream;")
          .sub("} // namespace\n", "} // namespace networkioagent_detail\nusing networkioagent_detail::Stream;\nusing networkioagent_detail::StreamsMap;\n")
        if patched != content
          File.write(network_io_h, patched)
          Pod::UI.puts "[NetworkIOAgent] Patched NetworkIOAgent.h to fix Clang module conflict".yellow
        end
      end
    end

    # Patch .cpp: ensure InitStreamError/InitStreamResult are visible outside
    # their namespace. Handles both anonymous and already-named namespaces.
    if File.exist?(network_io_cpp)
      content = File.read(network_io_cpp)
      patched = content
      if content.include?("namespace {\n\nstruct InitStreamResult")
        patched = patched
          .sub("namespace {\n\nstruct InitStreamResult", "namespace networkioagent_detail {\n\nstruct InitStreamResult")
          .sub("} // namespace\n\nNetworkIOAgent::~", "} // namespace networkioagent_detail\nusing namespace networkioagent_detail;\n\nNetworkIOAgent::~")
      elsif !content.include?('using networkioagent_detail::InitStreamError')
        patched = patched
          .sub(
            "} // namespace networkioagent_detail\n",
            "} // namespace networkioagent_detail\nusing networkioagent_detail::InitStreamError;\nusing networkioagent_detail::InitStreamResult;\n"
          )
      end
      if patched != content
        File.write(network_io_cpp, patched)
        Pod::UI.puts "[NetworkIOAgent] Patched NetworkIOAgent.cpp to fix Clang module conflict".yellow
      end
    end
  end
end
