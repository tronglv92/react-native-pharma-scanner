{
  "name": "react-native-pharma-scanner",
  "version": "0.1.0",
  "description": "React Native document scanning library with pluggable AI providers for structured data extraction",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "ios",
    "!ios/build",
    "pharmascanner",
    "!pharmascanner/build",
    "!pharmascanner/.cxx",
    "!pharmascanner/.gradle",
    "!pharmascanner/.settings",
    "nitrogen",
    "react-native-pharma-scanner.podspec",
    "react-native.config.js"
  ],
  "scripts": {
    "android": "cd example && react-native run-android",
    "ios": "cd example && react-native run-ios",
    "lint": "eslint .",
    "start": "cd example && react-native start",
    "test": "jest",
    "build": "bob build",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "document-scanner",
    "ocr",
    "ai-extraction",
    "pharma",
    "barcode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/react-native-pharma-scanner"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-nitro-modules": ">=0.35.0"
  },
  "peerDependenciesMeta": {
    "react-native-nitro-modules": {
      "optional": false
    }
  },
  "dependencies": {
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "nitrogen": "^0.35.7",
    "prettier": "2.8.8",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.35.3",
    "react-native-nitro-modules": "^0.35.7",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "copyFlow": false
        }
      ],
      [
        "module",
        {
          "copyFlow": false
        }
      ],
      ["typescript", { "project": "tsconfig.build.json" }]
    ]
  }
}
